# ============================================================
#  Kompas — konfiguracja dostawców danych
#  Skopiuj ten plik jako ".env" i wklej swoje klucze.
#  Bez kluczy aplikacja działa na danych DEMO (provider "mock").
# ============================================================

# Port serwera (opcjonalnie)
PORT=3000

# --- Hotelbeds APItude (środowisko testowe / sandbox) ---
# Rejestracja: https://developer.hotelbeds.com  ->  darmowe konto -> "APItude" -> klucz + secret
# Na start zostaw endpoint testowy. Produkcję włączysz później zmieniając HOTELBEDS_ENV na "prod".
HOTELBEDS_API_KEY=
HOTELBEDS_SECRET=
HOTELBEDS_ENV=test

# --- Ratehawk / Emerging Travel Group (opcjonalnie, druga faza) ---
RATEHAWK_KEY_ID=
RATEHAWK_API_KEY=

# --- TravelLead.pl (program afiliacyjny Wakacje.pl) ---
# Po akceptacji konta wydawcy: panel wydawcy -> feed produktowy (XML) + ID partnera.
TRAVELLEAD_FEED_URL=
TRAVELLEAD_PARTNER_ID=

# --- MerlinX (system agencyjny; wymaga konta agencyjnego) ---
MERLINX_URL=
MERLINX_LOGIN=
MERLINX_PASSWORD=
MERLINX_SYSTEM=
